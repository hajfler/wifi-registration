# ============================================================
# WLAN-Registrierungsportal - Konfiguration
# Kopiere diese Datei nach .env und fülle die Werte aus
# ============================================================

# Server
PORT=3000

# ============================================================
# UniFi Controller
# ============================================================
UNIFI_HOST=https://192.168.1.1
# Bei UniFi OS Consoles (UDM, UDM Pro): https://192.168.1.1
# Bei klassischem Controller: https://192.168.1.1:8443

UNIFI_USERNAME=admin
UNIFI_PASSWORD=dein-passwort
UNIFI_SITE=default
# WLAN-Name exakt wie im UniFi Controller konfiguriert:
UNIFI_WLAN_NAME=GuestWLAN
# Netzwerk-Name für PPSK (VLAN-Zuweisung), exakt wie in UniFi unter Networks:
UNIFI_NETWORK_NAME=net-WLAN

# Selbstsignierte Zertifikate erlauben (true bei lokalem Controller)
UNIFI_REJECT_UNAUTHORIZED=false

# ============================================================
# SMTP E-Mail
# ============================================================
SMTP_HOST=mail.example.com
SMTP_PORT=587
# true für Port 465 (SSL), false für Port 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=wlan@example.com
SMTP_PASS=mail-passwort
SMTP_FROM="WLAN-Registrierung <wlan@example.com>"

# ============================================================
# App
# ============================================================
# Basis-URL der App (für Links in E-Mails)
BASE_URL=http://localhost:3000

# ============================================================
# Admin-Bereich (/admin)
# ============================================================
ADMIN_PASSWORD=sicheres-admin-passwort
# Zugangscode für die Registrierungsseite (leer lassen = offen für alle):
REGISTER_PASSWORD=zugangscode-fuer-registrierung
# Zufälliger geheimer String für Session-Tokens (min. 32 Zeichen):
SESSION_SECRET=zufaelliger-geheimer-string-min-32-zeichen

# ============================================================
# IP-Whitelist (optional)
# ============================================================
# Kommagetrennte Liste von IPs oder CIDR-Blöcken, die auf die
# Registrierungsseite zugreifen dürfen. Leer lassen = offen für alle.
# Der Admin-Bereich (/admin) ist NICHT eingeschränkt.
ALLOWED_IPS=172.16.15.0/24,172.16.16.0/24,172.16.17.0/24,172.16.18.0/24,172.16.19.0/24,172.16.20.0/24,172.16.26.0/24,172.16.32.0/20,192.168.201.2,85.195.227.176/29,77.109.183.72/30
